{
  "name": "lan-chat",
  "version": "0.7.23",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "prerelease": "electron-rebuild -f -w better-sqlite3",
    "release": "dotenv -e .env -- sh -c 'vite build && electron-builder --publish always'",
    "pretest": "npm rebuild better-sqlite3",
    "test": "jest --testPathPatterns=tests/",
    "postinstall": "electron-builder install-app-deps"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.internal.lan-chat",
    "productName": "LAN Chat",
    "directories": {
      "output": "dist/app"
    },
    "files": [
      "dist/renderer/**",
      "electron/**",
      "node_modules/**",
      "!node_modules/lucide-react/**",
      "!node_modules/react/**",
      "!node_modules/react-dom/**",
      "!node_modules/scheduler/**",
      "!node_modules/emoji-picker-react/**",
      "!node_modules/emoji-datasource*/**",
      "!node_modules/zustand/**",
      "!node_modules/flairup/**",
      "!node_modules/@tiptap/**",
      "!node_modules/prosemirror-*/**",
      "!node_modules/tiptap-markdown/**",
      "!node_modules/react-markdown/**",
      "!node_modules/remark-*/**",
      "!node_modules/unified/**",
      "!node_modules/mdast-*/**",
      "!node_modules/micromark*/**",
      "!node_modules/better-sqlite3/deps/**",
      "!node_modules/better-sqlite3/src/**",
      "!node_modules/**/{test,tests,spec,__tests__}/**",
      "!node_modules/**/*.{md,markdown,txt,rst,map}",
      "!node_modules/**/{.bin,.github,.nyc_output}/**"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "extraResources": [
      "CHANGELOG.json",
      "logo.png"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "logo.png"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "whalstndla",
      "repo": "lan-chat",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "better-sqlite3": "^12.6.2",
    "bonjour-service": "^1.3.0",
    "electron-updater": "^6.8.3",
    "emoji-picker-react": "^4.18.0",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.9.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
