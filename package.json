{
  "name": "lan-chat",
  "version": "0.4.2",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "dotenv -e .env -- sh -c 'vite build && electron-builder'",
    "release": "dotenv -e .env -- sh -c 'vite build && electron-builder --publish always'",
    "test": "jest --testPathPattern=tests/",
    "postinstall": "electron-builder install-app-deps"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.internal.lan-chat",
    "productName": "LAN Chat",
    "directories": {
      "output": "dist/app"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "icon": "logo.png"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "whalstndla",
      "repo": "lan-chat",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "bonjour-service": "^1.3.0",
    "electron-updater": "^6.8.3",
    "emoji-picker-react": "^4.18.0",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
